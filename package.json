{
    "name": "express-ts-template",
    "version": "1.0.0",
    "description": "Production-ready Express + TypeScript + Prisma + PostgreSQL + Redis API template.",
    "main": "dist/src/server.js",
    "scripts": {
        "dev": "cross-env NODE_ENV=development ts-node-dev --files server.ts",
        "test": "cross-env NODE_ENV=test jest",
        "build": "tsc",
        "start": "node dist/src/server.js",
        "test:coverage": "NODE_ENV=test jest --coverage",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write \"**/*.{ts,js,json,md,yml,yaml}\"",
        "format:check": "prettier --check \"**/*.{ts,js,json,md,yml,yaml}\"",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:deploy": "prisma migrate deploy",
        "db:push": "prisma db push",
        "db:studio": "prisma studio",
        "db:seed": "ts-node prisma/seed.ts",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "docker:reset": "docker compose down -v && docker compose up -d"
    },
    "keywords": [
        "express",
        "typescript",
        "prisma",
        "postgresql",
        "redis",
        "rest-api",
        "template",
        "boilerplate"
    ],
    "author": "",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0 <23.0.0",
        "pnpm": ">=8.0.0"
    },
    "dependencies": {
        "@prisma/client": "^5.22.0",
        "bcryptjs": "^3.0.3",
        "chalk": "^4.1.2",
        "connect-redis": "^7.0.1",
        "cookie-parser": "^1.4.6",
        "cors": "^2.8.5",
        "dotenv": "^16.0.3",
        "express": "^4.18.2",
        "express-rate-limit": "^7.1.2",
        "express-session": "^1.17.3",
        "jsonwebtoken": "^9.0.0",
        "morgan": "^1.10.1",
        "nodemailer": "^7.0.11",
        "redis": "^4.6.5",
        "socket.io": "^4.8.1",
        "winston": "^3.18.3",
        "winston-daily-rotate-file": "^5.0.0"
    },
    "devDependencies": {
        "@types/bcryptjs": "^2.4.6",
        "@types/cookie-parser": "^1.4.10",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.5",
        "@types/express-session": "^1.18.2",
        "@types/jest": "^30.0.0",
        "@types/jsonwebtoken": "^9.0.10",
        "@types/morgan": "^1.9.10",
        "@types/node": "^24.10.1",
        "@types/nodemailer": "^7.0.4",
        "@types/supertest": "^6.0.3",
        "@typescript-eslint/eslint-plugin": "^8.48.0",
        "@typescript-eslint/parser": "^8.48.0",
        "eslint": "^9.39.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.4",
        "jest": "^29.5.0",
        "prettier": "^3.7.3",
        "prisma": "^5.22.0",
        "supertest": "^7.1.3",
        "ts-jest": "^29.4.6",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "typescript": "^5.9.3"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    }
}
