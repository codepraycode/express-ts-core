# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
NODE_ENV=development
PORT=8080

# URL of your front-end application (used for CORS and email links)
CLIENT_URL=http://localhost:3000

# ---------------------------------------------------------------------------
# Database — PostgreSQL (Prisma reads this directly)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
# ---------------------------------------------------------------------------
DATABASE_URL=postgresql://root:password@localhost:5432/app_db

# Docker Compose convenience vars (used in docker-compose.yml)
DB_USER=root
DB_PASSWORD=password
DB_NAME=app_db

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# ---------------------------------------------------------------------------
# Authentication
# ---------------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_EXPIRES_IN=1h
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Email — SMTP
# For local development, use Ethereal (https://ethereal.email) or Mailpit
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=no-reply@example.com
EMAIL_TIMEOUT=10000

# ---------------------------------------------------------------------------
# Logging
# ---------------------------------------------------------------------------
ENABLE_FILE_LOGGING=false